# ForgePass environment — copy to `.env.local` and fill in after deploying.
#
# When BOTH IDs below are set to real Soroban contract IDs, the app flips the
# Stellar Verification Record from "(simulated)" to on-chain mode
# (lib/stellar/config.ts → HAS_LIVE_CONTRACTS) and links the explorer.
#
# Get IDs by running:  ./scripts/deploy-testnet.sh        (macOS/Linux/WSL)
#                  or:  ./scripts/deploy-testnet.ps1       (Windows PowerShell)
# The script prints the exact two lines to paste here.

NEXT_PUBLIC_FORGEPASS_VERIFIER_ID=
NEXT_PUBLIC_FORGEPASS_REGISTRY_ID=
