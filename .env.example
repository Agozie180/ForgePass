# Live Stellar Testnet deployment verified via Soroban RPC on 2026-06-25.
# Setting both contract IDs flips lib/stellar/config.ts -> HAS_LIVE_CONTRACTS = true.
# The browser proof animation and full native on-chain proof verification remain
# transparently scaffolded until the UltraHonk transaction path is wired.

NEXT_PUBLIC_STELLAR_NETWORK=Testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

NEXT_PUBLIC_FORGEPASS_VERIFIER_ID=CCNNXYINWM3QNC3HNKOU66XCJP5GJMZYMSMXYBZALT4U24AXN6RAPXNF
NEXT_PUBLIC_FORGEPASS_REGISTRY_ID=CABRLKSOTTR3YSMXQUPLTBR3QBDIOC5SLPIIX7VI2JPLLTHWL4BQBDOT

