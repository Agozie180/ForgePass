{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"1571102628690551038","abi":{"parameters":[{"name":"monthly_income_usd","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"average_balance_usd","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"account_age_months","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"eligible_transactions","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"consistent_months","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"observed_months","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"threshold","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"policy_commitment","type":{"kind":"field"},"visibility":"public"},{"name":"holder_binding","type":{"kind":"field"},"visibility":"public"},{"name":"nullifier","type":{"kind":"field"},"visibility":"public"},{"name":"qualified","type":{"kind":"boolean"},"visibility":"public"}],"return_type":null,"error_types":{"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"fn capped_points(value: u64, points: u64, target: u64) -> u64 {\n    let earned = value * points / target;\n    if earned > points { points } else { earned }\n}\n\nfn main(\n    monthly_income_usd: u64,\n    average_balance_usd: u64,\n    account_age_months: u64,\n    eligible_transactions: u64,\n    consistent_months: u64,\n    observed_months: u64,\n    threshold: pub u64,\n    policy_commitment: pub Field,\n    holder_binding: pub Field,\n    nullifier: pub Field,\n    qualified: pub bool,\n) {\n    assert(observed_months > 0);\n    assert(consistent_months <= observed_months);\n    assert(threshold <= 100);\n\n    // Public bindings are consumed by the verifier receipt and cannot be zero.\n    assert(policy_commitment != 0);\n    assert(holder_binding != 0);\n    assert(nullifier != 0);\n\n    let income = capped_points(monthly_income_usd, 25, 8000);\n    let balance = capped_points(average_balance_usd, 20, 3000);\n    let age = capped_points(account_age_months, 20, 24);\n    let activity = capped_points(eligible_transactions, 20, 120);\n    let consistency = consistent_months * 15 / observed_months;\n    let score = income + balance + age + activity + consistency;\n\n    assert(score <= 100);\n    assert(qualified == (score > threshold));\n    assert(qualified);\n}\n\n#[test]\nfn demo_score_qualifies() {\n    main(8000, 3000, 18, 120, 9, 12, 80, 1, 2, 3, true);\n}\n\n#[test(should_fail)]\nfn low_score_cannot_claim_qualification() {\n    main(1000, 200, 2, 5, 1, 12, 80, 1, 2, 3, true);\n}\n","path":"/tmp/forgepass-noir-beta9-all/circuits/trust_score_proof/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient","directive_invert"]}